/* =============================================
   PROYECTO: ATLAS
   CAPA: BRONZE
   OBJETO: product_master
   DESCRIPCIÓN: Carga de datos crudos del maestro de productos.
============================================= */

-- 1. Asegurar que el esquema bronze exista en la base de Aurora
CREATE SCHEMA IF NOT EXISTS bronze;

-- 2. Limpieza de tabla previa para evitar duplicados en la estructura
DROP TABLE IF EXISTS bronze.product_master;

-- 3. Creación de tabla con tipos de datos exactos de la documentación Atlas
CREATE TABLE bronze.product_master (
    pm_sku          VARCHAR(20),
    pm_manid        VARCHAR(20),
    pm_description  VARCHAR(100),
    pm_category     VARCHAR(30),
    pm_material     VARCHAR(30),
    pm_diameter     VARCHAR(10),
    pm_tickness     VARCHAR(10), -- Mantenido como 'tickness' según tu imagen
    pm_length       VARCHAR(10),
    pm_oum          VARCHAR(20),
    pm_pressure     VARCHAR(15),
    pm_coatfinish   VARCHAR(20),
    pm_connection   VARCHAR(20),
    pm_status       VARCHAR(10),
    pm_branch       CHAR(1),     -- Tipo de dato fijo para sucursal
    pm_leadtimeday  INT          -- Valor numérico para días de entrega
);

-- Comentario de auditoría para el equipo de Atlas
COMMENT ON TABLE bronze.product_master IS 'Maestro de productos - Fuente original (Atlas Project)';

