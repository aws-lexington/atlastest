import json
import requests
import boto3
import base64
import io
import PyPDF2
import pandas as pd

# === CONFIGURACIÓN ===
TENANT_ID = 
CLIENT_ID = 
CLIENT_SECRET = 
USER_EMAIL = 
BUCKET_S3 =

DOMINIOS_OK = ['enerfuel.com', 'acmefuel.com', 'fueltech.com', 'mwps.com', 'pricesupdate.com', 'lexng.com', 'gmail.com']

KEYWORDS_INVOICE = ['invoice', 'to date', 'ship to', 'total due', 'bill to']
KEYWORDS_PRICE_LIST = ['price list', 'lista de precios', 'wholesale', 'price sheet', 'precio', 'lista']

def lambda_handler(event, context):
    # --- PASO 1: Token ---
    auth_url = f"https://login.microsoftonline.com/{TENANT_ID}/oauth2/v2.0/token"
    data = {
        'client_id': CLIENT_ID, 
        'scope': 'https://graph.microsoft.com/.default', 
        'client_secret': CLIENT_SECRET, 
        'grant_type': 'client_credentials'
    }
    
    token_res = requests.post(auth_url, data=data).json()
    access_token = token_res.get('access_token')
    if not access_token:
        return {"error": "Error de Token", "detalle": token_res}

    headers = {'Authorization': f'Bearer {access_token}'}

    # --- PASO 2: Carpeta Demo ---
    folder_url = f"https://graph.microsoft.com/v1.0/users/{USER_EMAIL}/mailFolders/inbox/childFolders"
    folders = requests.get(folder_url, headers=headers).json().get('value', [])
    folder_id = next((f['id'] for f in folders if f['displayName'] == "Demo"), None)

    if not folder_id:
        return {"error": "Carpeta Demo no encontrada"}

    # --- PASO 3: Procesar Mensajes ---
    messages_url = f"https://graph.microsoft.com/v1.0/users/{USER_EMAIL}/mailFolders/{folder_id}/messages"
    messages = requests.get(messages_url, headers=headers).json().get('value', [])
    
    s3 = boto3.client('s3')
    counts = {"invoices": 0, "price_lists": 0, "garbage": 0}
    
    # NEW: Tracking set to prevent duplicates in the same run
    processed_files = set()

    for msg in messages:
        sender = msg.get('from', {}).get('emailAddress', {}).get('address', '').lower()
        
        if any(sender.endswith(dom) for dom in DOMINIOS_OK):
            msg_id = msg['id']
            att_url = f"https://graph.microsoft.com/v1.0/users/{USER_EMAIL}/messages/{msg_id}/attachments"
            attachments = requests.get(att_url, headers=headers).json().get('value', [])
            
            for att in attachments:
                filename = att['name']
                filename_lower = filename.lower()
                is_file = att['@odata.type'] == '#microsoft.graph.fileAttachment'
                
                # Check for duplication
                if filename in processed_files:
                    continue
                
                if is_file and filename_lower.endswith(('.pdf', '.xlsx', '.csv')):
                    raw_content = base64.b64decode(att['contentBytes'])
                    texto_interno = ""
                    
                    try:
                        if filename_lower.endswith('.pdf'):
                            pdf_reader = PyPDF2.PdfReader(io.BytesIO(raw_content))
                            texto_interno = "".join([page.extract_text().lower() for page in pdf_reader.pages if page.extract_text()])
                        
                        elif filename_lower.endswith('.xlsx'):
                            # Try reading with openpyxl engine
                            df = pd.read_excel(io.BytesIO(raw_content), engine='openpyxl')
                            texto_interno = df.to_string().lower()
                        
                        elif filename_lower.endswith('.csv'):
                            content_str = raw_content.decode('utf-8', errors='ignore')
                            texto_interno = content_str.lower()
                        
                        search_blob = (texto_interno + " " + filename_lower).lower()

                        # --- ROUTING LOGIC ---
                        # We use the original 'filename' for S3 Key to preserve casing in the bucket
                        if any(k.lower() in search_blob for k in KEYWORDS_PRICE_LIST):
                            s3.put_object(Bucket=BUCKET_S3, Key=f"price-lists/{filename}", Body=raw_content)
                            print(f"🏷️ Price List: {filename}")
                            counts["price_lists"] += 1
                        
                        elif any(k.lower() in search_blob for k in KEYWORDS_INVOICE):
                            s3.put_object(Bucket=BUCKET_S3, Key=f"invoices/{filename}", Body=raw_content)
                            print(f"✅ Invoice: {filename}")
                            counts["invoices"] += 1
                        
                        else:
                            s3.put_object(Bucket=BUCKET_S3, Key=f"garbage/{filename}", Body=raw_content)
                            print(f"🗑️ Garbage: {filename}")
                            counts["garbage"] += 1
                        
                        # Mark as processed so we don't upload it again if it appears in another email
                        processed_files.add(filename)
                            
                    except Exception as e:
                        print(f"⚠️ Error processing {filename}: {e}")

    return {
        'statusCode': 200,
        'body': json.dumps(f"Proceso completo. Price Lists: {counts['price_lists']}, Invoices: {counts['invoices']}, Garbage: {counts['garbage']}")
    }
