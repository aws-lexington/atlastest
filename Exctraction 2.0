import json
import requests
import boto3
import base64
import io
import PyPDF2
import pandas as pd  # Added for Excel support

# === CONFIGURACIÓN ===
# Tip: Consider moving these to Configuration > Environment variables
TENANT_ID = ""
CLIENT_ID = ""
CLIENT_SECRET = "" 
USER_EMAIL = ""
BUCKET_S3 = "s"

DOMINIOS_OK = ['enerfuel.com', 'acmefuel.com', 'fueltech.com', 'mwps.com', 'pricesupdate.com', 'lexng.com', 'gmail.com']
KEYWORDS = ['invoice', 'to date', 'ship to', 'total due', 'price', 'lista']

def lambda_handler(event, context):
    # --- PASO 1: Token ---
    auth_url = f"https://login.microsoftonline.com/{TENANT_ID}/oauth2/v2.0/token"
    data = {
        'client_id': CLIENT_ID, 
        'scope': 'https://graph.microsoft.com/.default', 
        'client_secret': CLIENT_SECRET, 
        'grant_type': 'client_credentials'
    }
    token_res = requests.post(auth_url, data=data).json()
    access_token = token_res.get('access_token')
    
    if not access_token:
        return {"error": "Error de Token", "detalle": token_res}

    headers = {'Authorization': f'Bearer {access_token}'}

    # --- PASO 2: Carpeta Demo ---
    folder_url = f"https://graph.microsoft.com/v1.0/users/{USER_EMAIL}/mailFolders/inbox/childFolders"
    folders = requests.get(folder_url, headers=headers).json().get('value', [])
    folder_id = next((f['id'] for f in folders if f['displayName'] == "Demo"), None)

    if not folder_id:
        return {"error": "Carpeta Demo no encontrada"}

    # --- PASO 3: Procesar Mensajes ---
    messages_url = f"https://graph.microsoft.com/v1.0/users/{USER_EMAIL}/mailFolders/{folder_id}/messages"
    messages = requests.get(messages_url, headers=headers).json().get('value', [])
    
    s3 = boto3.client('s3')
    count_ok = 0
    count_garbage = 0

    for msg in messages:
        sender = msg['from']['emailAddress']['address'].lower()
        # Stricter domain check
        if any(sender.endswith(dom) for dom in DOMINIOS_OK):
            msg_id = msg['id']
            att_url = f"https://graph.microsoft.com/v1.0/users/{USER_EMAIL}/messages/{msg_id}/attachments"
            attachments = requests.get(att_url, headers=headers).json().get('value', [])
            
            for att in attachments:
                # Updated filter to include .xlsx
                filename = att['name'].lower()
                is_file = att['@odata.type'] == '#microsoft.graph.fileAttachment'
                
                if is_file and filename.endswith(('.pdf', '.xlsx')):
                    raw_content = base64.b64decode(att['contentBytes'])
                    texto_interno = ""
                    
                    try:
                        # Logic for PDF
                        if filename.endswith('.pdf'):
                            pdf_reader = PyPDF2.PdfReader(io.BytesIO(raw_content))
                            texto_interno = "".join([page.extract_text().lower() for page in pdf_reader.pages])
                        
                        # Logic for Excel
                        elif filename.endswith('.xlsx'):
                            df = pd.read_excel(io.BytesIO(raw_content))
                            texto_interno = df.to_string().lower()
                        
                        # --- LÓGICA DE FILTRADO ---
                        if any(k in texto_interno for k in KEYWORDS) or any(k in filename for k in KEYWORDS):
                            s3.put_object(Bucket=BUCKET_S3, Key=f"invoices/{att['name']}", Body=raw_content)
                            print(f"✅ Válido: {att['name']}")
                            count_ok += 1
                        else:
                            s3.put_object(Bucket=BUCKET_S3, Key=f"garbage/{att['name']}", Body=raw_content)
                            print(f"🗑️ Basura: {att['name']}")
                            count_garbage += 1
                            
                    except Exception as e:
                        print(f"⚠️ Error en {att['name']}: {e}")

    return {
        'statusCode': 200,
        'body': json.dumps(f'Proceso terminado. Invoices: {count_ok}, Garbage: {count_garbage}')
    }
